{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(git *)",
      "Bash(bash tests/*)",
      "Bash(./pgtool.sh *)",
      "Bash(./install.sh *)",
      "Bash(ls*)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(chmod +x *.sh)",
      "Bash(chmod +x commands/*/*.sh)",
      "Bash(mkdir *)",
      "Bash(rm -f .worktrees/*)",
      "Bash(rm -rf .worktrees/*)",
      "Bash(psql *)",
      "Bash(createdb *)",
      "Bash(dropdb *)",
      "Bash(pg_dump *)",
      "Bash(pg_restore *)",
      "Bash(npx *)",
      "Bash(npm *)",
      "Bash(which *)",
      "Bash(test *)",
      "Bash(echo *)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(git*)"
    ],
    "deny": [
      "Bash(*> /dev/null*)",
      "Bash(*sudo*)",
      "Bash(*rm -rf /*)",
      "Bash(*rm -rf ~/*)",
      "Bash(*rm -rf $HOME*)",
      "Bash(*chmod 777*)",
      "Bash(*chmod 666*)",
      "Bash(*ssh *)",
      "Bash(*curl *|*sh*)",
      "Bash(*wget *|*sh*)",
      "Bash(*eval*)",
      "Bash(*exec*)",
      "Bash(*system*)",
      "Bash(*fork*)",
      "Bash(*> ~/.bashrc*)",
      "Bash(*> ~/.zshrc*)",
      "Bash(*>> ~/.bashrc*)",
      "Bash(*>> ~/.zshrc*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '🚨 SECURITY WARNING: Potentially dangerous command detected. Review before proceeding.'"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '⚠️  Potential secret or sensitive file write detected.'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git diff --name-only && echo '📋 Session ending. Uncommitted changes (if any) listed above.'"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  }
}
