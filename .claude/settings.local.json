{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(git *)",
      "Bash(bash tests/*)",
      "Bash(./pgtool.sh *)",
      "Bash(./install.sh *)",
      "Bash(ls*)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(chmod +x *.sh)",
      "Bash(chmod +x commands/*/*.sh)",
      "Bash(mkdir *)",
      "Bash(rm -f .worktrees/*)",
      "Bash(rm -rf .worktrees/*)",
      "Bash(psql *)",
      "Bash(createdb *)",
      "Bash(dropdb *)",
      "Bash(pg_dump *)",
      "Bash(pg_restore *)",
      "Bash(npx *)",
      "Bash(npm *)",
      "Bash(which *)",
      "Bash(test *)",
      "Bash(echo *)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(git*)"
    ],
    "deny": [
      "Bash(*> /dev/null*)",
      "Bash(*sudo*)",
      "Bash(*rm -rf /*)",
      "Bash(*rm -rf ~/*)",
      "Bash(*rm -rf $HOME*)",
      "Bash(*chmod 777*)",
      "Bash(*chmod 666*)",
      "Bash(*ssh *)",
      "Bash(*curl *|*sh*)",
      "Bash(*wget *|*sh*)",
      "Bash(*eval*)",
      "Bash(*exec*)",
      "Bash(*system*)",
      "Bash(*fork*)",
      "Bash(*> ~/.bashrc*)",
      "Bash(*> ~/.zshrc*)",
      "Bash(*>> ~/.bashrc*)",
      "Bash(*>> ~/.zshrc*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "tool": "Bash",
        "pattern": "(sudo|su -|rm -rf /|curl.*\\|.*sh|wget.*\\|.*sh|eval\\s*\\(|exec\\s*\\(|system\\s*\\(|fork\\s*\\()",
        "message": "🚨 SECURITY WARNING: Potentially dangerous command detected. Review before proceeding."
      },
      {
        "tool": "Write",
        "pattern": "(\\.ssh/|\\.aws/|\\.pgpass|id_rsa|private_key|password|secret|token)",
        "message": "⚠️  Potential secret or sensitive file write detected."
      }
    ],
    "Stop": [
      {
        "command": "git diff --name-only",
        "message": "📋 Session ending. Uncommitted changes (if any) listed above."
      }
    ]
  }
}
